                });

              
                if (window.location.search.substr(1).split("=")[1] == "nodistraction") {
                   
                    $("#menu-top-menu").addClass("nodistraction");
                    $(".header-title-bar").addClass("nodistraction");
                    $("#ctl00_cph1_pnlButtons").addClass("hidden");
