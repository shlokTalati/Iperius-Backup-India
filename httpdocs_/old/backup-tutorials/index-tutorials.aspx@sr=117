    <table style="border:solid 0px white; width:100%;">
        <tr>
            <td style="font-weight:bold; font-size:13pt;">
                <a id="ctl00_cph1_LangUserControl_ListView1_ctrl3_HyperLink1" href="https://www.iperiusbackup.net/en/online-backup-vs-external-hard-drive-backup/" target="_blank"><font color="#444444">Online backup vs backup on an external hard drive</font></a>
