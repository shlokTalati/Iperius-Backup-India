                    }
                    if (hash == "#sql") {
                        $('#containerslide').css("left", "-520px");
                        e.preventDefault();
                    }
                    if (hash == "#exchange") {
                        $('#containerslide').css("left", "-790px");
                        e.preventDefault();
                    }
                    if (hash == "#tape") {
                        $('#containerslide').css("left", "-1050px");
                        e.preventDefault();
