					        currLink.addClass("active");
					        $('.nav-active').show();
					        var spanTop = $('.active').offset().left - $('.nav').offset().left;
					        var navWidth = $(this).outerWidth();
					        $('.nav .nav-active').css({"left":spanTop,"width":navWidth});
